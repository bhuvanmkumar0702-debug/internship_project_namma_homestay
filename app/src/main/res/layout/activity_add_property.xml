<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="List Your HomeStay"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/nameEt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="HomeStay Name"
            android:inputType="textCapWords"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/locationEt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Location (e.g. Madikeri, KA)"
            android:inputType="textCapWords"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/priceEt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Price per night (₹)"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/imageEt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Image URL (Link to photo)"
            android:inputType="textUri"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Post Property"
            android:padding="12dp"
            android:backgroundTint="#FF5722"/>

        <Button
            android:id="@+id/importStaysBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Import Karnataka Stays (All Districts)"
            android:layout_marginTop="16dp"
            android:backgroundTint="#4CAF50"
            style="@style/Widget.Material3.Button.TextButton"/>

    </LinearLayout>
</ScrollView>
